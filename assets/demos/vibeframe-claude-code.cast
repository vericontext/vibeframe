[0.009, "o", "\u001b[1;37mVibeFrame inside Claude Code — MCP integration\u001b[0m\r\n"]
[0.000, "o", "\u001b[2mOne config block, 62 vibe tools attached to your Claude Code session.\u001b[0m\r\n"]
[2.007, "o", "\r\n\u001b[1;36m── one-time setup ──\u001b[0m\r\n"]
[0.610, "o", "~/.config/claude-code/mcp.json\r\n{\r\n  \"mcpServers\": {\r\n    \"vibeframe\": {\r\n      \"command\": \"npx\",\r\n      \"args\": [\"-y\", \"@vibeframe/mcp-server\"]\r\n    }\r\n  }\r\n}\r\n"]
[2.515, "o", "\r\n\u001b[1;36m── live Claude Code session ──\u001b[0m\r\n"]
[0.506, "o", "\r\n\u001b[1;32m❯\u001b[0m \u001b[1;37mUse the vibeframe MCP tools to scaffold a 16:9 scene project named 'cc-demo' with 6 second duration, then add an 'announcement' scene named 'hello' with the headline 'Hello from Claude Code' (skip audio and image), then lint it. Brief summary at the end.\u001b[0m\r\n\r\n"]
[3.030, "o", "\u001b[2mclaude code · session start · 63 tools available · vibeframe MCP server connected\u001b[0m\r\n"]
