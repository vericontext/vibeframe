[0.864, "o", "Usage: vibe agent [options]\r\n\r\nStart the AI agent with natural language interface\r\n\r\nOptions:\r\n  -p, --provider <provider>  LLM provider (openai, claude, gemini, ollama, xai,\r\n                             openrouter) (default: \"openai\")\r\n  -m, --model <model>        Model to use (provider-specific)\r\n  --project <path>           Project file to load\r\n  -v, --verbose              Show verbose output including tool calls\r\n"]
[0.003, "o", "\u001b[1;33m→ Bring your own LLM — Claude, OpenAI, Gemini, Grok, OpenRouter, or local Ollama.\u001b[0m\r\n"]
[1.407, "o", "\r\n\u001b[1;36m── 2 · ask in plain English (single-shot via -i) ──\u001b[0m\r\n"]
