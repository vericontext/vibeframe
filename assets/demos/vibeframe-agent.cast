[0.011, "o", "\u001b[1;37mVibeFrame agent mode — stand-alone REPL, no IDE host, no MCP setup\u001b[0m\r\n"]
[0.000, "o", "\u001b[2mPick any LLM provider (BYOK), get 62 vibe tools attached automatically.\u001b[0m\r\n"]
[2.007, "o", "\r\n\u001b[1;36m── 1 · pick a provider ──\u001b[0m\r\n"]
[0.608, "o", "\u001b[1;32m❯\u001b[0m v"]
