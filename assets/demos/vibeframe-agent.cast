[0.009, "o", "\u001b[1;37mVibeFrame agent mode — natural language → multi-tool orchestration\u001b[0m\r\n"]
[0.000, "o", "\u001b[2mOne CLI flag opens an LLM-driven REPL with 62 vibe tools attached.\u001b[0m\r\n"]
[2.007, "o", "\r\n\u001b[1;36m── 1 · pick a provider ──\u001b[0m\r\n"]
