[0.007, "o", "\u001b[1;37mVibeFrame v0.55 — script to narrated MP4 in 90 seconds.\u001b[0m\r\n"]
[0.000, "o", "\u001b[2mNo API keys required. All output stays local.\u001b[0m\r\n"]
