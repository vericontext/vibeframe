[0.000, "o", "\r\n\u001b[1m\u001b[36mNext steps\u001b[39m\u001b[22m\r\n\u001b[2m────────────────────────────────────────────────────────────\u001b[22m\r\n  \u001b[36mvibe scene add\u001b[39m <name>    \u001b[2m# author a scene via AI\u001b[22m\r\n  \u001b[36mvibe scene lint\u001b[39m          \u001b[2m# validate HTML\u001b[22m\r\n  \u001b[36mvibe scene render\u001b[39m        \u001b[2m# render to MP4\u001b[22m\r\n"]
[0.000, "o", "\u001b[?25h"]
[0.002, "o", "\u001b[1;33m→ 6 files written. Bilingual project — works with both vibe and npx hyperframes.\u001b[0m\r\n"]
