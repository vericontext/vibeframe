{
  "name": "@vibeframe/cli",
  "version": "0.112.1",
  "description": "VibeFrame CLI - agentic video workflow runtime",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vericontext/vibeframe.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/vericontext/vibeframe/issues"
  },
  "keywords": [
    "vibeframe",
    "cli",
    "video-editing",
    "ai",
    "ffmpeg",
    "commander"
  ],
  "type": "module",
  "bin": {
    "vibe": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CONTEXT.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./engine": {
      "types": "./dist/engine/index.d.ts",
      "import": "./dist/engine/index.js"
    },
    "./tools/manifest": {
      "types": "./dist/tools/manifest/index.d.ts",
      "import": "./dist/tools/manifest/index.js"
    },
    "./tools/define-tool": {
      "types": "./dist/tools/define-tool.d.ts",
      "import": "./dist/tools/define-tool.js"
    },
    "./tools/adapters/mcp": {
      "types": "./dist/tools/adapters/mcp.d.ts",
      "import": "./dist/tools/adapters/mcp.js"
    },
    "./tools/adapters/agent": {
      "types": "./dist/tools/adapters/agent.d.ts",
      "import": "./dist/tools/adapters/agent.js"
    }
  },
  "scripts": {
    "build": "node build.js",
    "build:tsc": "tsc",
    "dev": "tsc --watch",
    "start": "tsx src/index.ts",
    "lint": "eslint --ext .ts,.tsx src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest": "node build.js",
    "prepublishOnly": "node build.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.21.0",
    "@hyperframes/producer": "^0.4.6",
    "@lottiefiles/dotlottie-wc": "^0.9.12",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^17.2.3",
    "image-size": "^2.0.2",
    "music-metadata": "^11.11.1",
    "openai": "^4.77.0",
    "ora": "^8.0.1",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  },
  "optionalDependencies": {
    "kokoro-js": "^1.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vibeframe/ai-providers": "workspace:*",
    "@vibeframe/core": "workspace:*",
    "@vitest/coverage-v8": "1",
    "@webgpu/types": "^0.1.69",
    "esbuild": "^0.24.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "engines": {
    "node": ">=20"
  }
}
